# WhatsApp Business Cloud API token (from Meta Business Suite)
WHATSAPP_TOKEN=your-whatsapp-token

# Phone Number ID (from WhatsApp Business API setup in Meta)
WHATSAPP_PHONE_NUMBER_ID=123456789

# Webhook verification token (you choose this, must match Meta webhook config)
WHATSAPP_VERIFY_TOKEN=nakopay-verify

# Your NakoPay merchant key
# Create one at https://nakopay.com/dashboard/api-keys
NAKOPAY_API_KEY=sk_test_replace_me

# NakoPay webhook signing secret (starts with whsec_)
NAKOPAY_WEBHOOK_SECRET=whsec_replace_me

# NakoPay API base URL (override only if self-hosting edge functions)
NAKOPAY_API_BASE=https://daslrxpkbkqrbnjwouiq.supabase.co/functions/v1

# Server port
PORT=3000

# Public base URL (for webhook URL display)
BASE_URL=https://your-server.com
